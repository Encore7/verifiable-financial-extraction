# Copy to .env and fill in. Mirrors src/config.py:Settings.

# LLM — required to run extractions (Anthropic / Claude).
ANTHROPIC_API_KEY=

# SEC EDGAR fair-access requires a descriptive User-Agent (e.g. "Name email").
SEC_USER_AGENT=

# Postgres (matches docker-compose.yml: postgres/postgres @ localhost:5432/vfe).
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vfe

# Observability — single OTLP gRPC endpoint (Grafana Alloy receiver, M4).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Filesystem root for immutable raw ELT landings.
LANDING_DIR=data/landings
